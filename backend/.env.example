# Database — leave DATABASE_URL unset to fall back to local SQLite (backend/aquasense.db)
DATABASE_URL=postgresql://aquasense:aquasense@localhost:5432/aquasense

# JWT
SECRET_KEY=change-me-to-a-random-64-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Open-Meteo has no API key requirement; base URLs are configurable for testing
OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
OPEN_METEO_ARCHIVE_URL=https://archive-api.open-meteo.com/v1/archive
